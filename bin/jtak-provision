#!/usr/bin/env bash
# jTAK Provisioning — run once after cloning an NVME to new hardware.
# Headless. Sets hostname, regenerates SSH/ZT identity, renames Meshtastic
# node, and writes jtak.identity.yaml for this hardware.
#
# Usage: sudo /opt/jtak/bin/jtak-provision --hub-number 4
#
# What this does NOT touch:
#   - TLS/OTS certs (self-signed, 10-year — no need)
#   - HQ registration (manual step — do via HQ admin after running this)
#   - ZeroTier authorization (manual step — approve in ZT Central after running)

set -euo pipefail

HUB_NUM=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --hub-number) HUB_NUM="$2"; shift 2 ;;
    *) echo "Unknown arg: $1"; exit 1 ;;
  esac
done

if [[ -z "$HUB_NUM" ]]; then
  echo "Usage: sudo /opt/jtak/bin/jtak-provision --hub-number N"
  exit 1
fi

HOSTNAME="jtak${HUB_NUM}"
HUB_ID="tak-${HUB_NUM}"
LONGNAME="jTAK HUB ${HUB_NUM}"
SHORTNAME="HUB${HUB_NUM}"
MESH_PYTHON="/opt/jtak/venv/bin/python3"

echo ""
echo "╔══════════════════════════════════════════════╗"
echo "║         jTAK Hub Provisioning                ║"
echo "╠══════════════════════════════════════════════╣"
echo "║  Hostname  : $HOSTNAME"
echo "║  Hub ID    : $HUB_ID"
echo "║  Longname  : $LONGNAME"
echo "║  Shortname : $SHORTNAME"
echo "╚══════════════════════════════════════════════╝"
echo ""

# ── Phase 1: Network Identity ─────────────────────────────────────────────────
echo "[1/5] Setting hostname → $HOSTNAME"
hostnamectl set-hostname "$HOSTNAME"

# Remove ALL existing 127.0.1.1 lines, then add exactly one correct entry
# Include the .local alias so the hub can resolve its own name without mDNS
sed -i '/^127\.0\.1\.1/d' /etc/hosts
echo "127.0.1.1	$HOSTNAME $HOSTNAME.local" >> /etc/hosts

echo "[1/5] Regenerating SSH host keys"
rm -f /etc/ssh/ssh_host_*
ssh-keygen -A
systemctl restart ssh

echo "[1/5] Regenerating ZeroTier identity"
systemctl stop zerotier-one
rm -f /var/lib/zerotier-one/identity.public /var/lib/zerotier-one/identity.secret
systemctl start zerotier-one
sleep 3
NEW_ZT_ID=$(zerotier-cli info | awk '{print $3}')
echo "      New ZeroTier node ID: $NEW_ZT_ID"

echo "[1/5] Writing AP DNS config → ${HOSTNAME}.local resolves to 10.42.0.1"
mkdir -p /etc/NetworkManager/dnsmasq-shared.d
echo "address=/${HOSTNAME}.local/10.42.0.1" > /etc/NetworkManager/dnsmasq-shared.d/jtak-hostname.conf

echo "[1/5] Updating WiFi AP SSID → $HOSTNAME"
# Find the hotspot connection (may be named 'Hotspot' or 'hotspot')
HOTSPOT_CON=$(nmcli -t -f NAME,TYPE con show | grep ':802-11-wireless' | head -1 | cut -d: -f1) || true
if [[ -n "$HOTSPOT_CON" ]]; then
  nmcli con modify "$HOTSPOT_CON" 802-11-wireless.ssid "$HOSTNAME"
  # Reconnect only if it's currently active — this also restarts NM's dnsmasq,
  # which picks up the jtak-hostname.conf we just wrote above.
  if nmcli -t -f NAME con show --active | grep -qx "$HOTSPOT_CON"; then
    nmcli con down "$HOTSPOT_CON" || true
    sleep 1
    nmcli con up "$HOTSPOT_CON" || true
  fi
  echo "      WiFi AP SSID set to: $HOSTNAME"
else
  echo "      WARNING: No WiFi AP connection found — set SSID manually"
fi

# ── Phase 2: Meshtastic ───────────────────────────────────────────────────────
echo "[2/5] Regenerating Meshtastic PKC key pair (unique per hub)"
"/opt/jtak/venv/bin/meshtastic" --host localhost --port 4403 \
  --set security.private_key "" --set security.public_key "" 2>/dev/null || true
systemctl restart meshtasticd
sleep 10

echo "[2/5] Renaming Meshtastic node → $LONGNAME / $SHORTNAME"
"$MESH_PYTHON" - <<PYEOF || true
import meshtastic.tcp_interface, time
iface = meshtastic.tcp_interface.TCPInterface('localhost', portNumber=4403)
time.sleep(2)
iface.localNode.setOwner(long_name="$LONGNAME", short_name="$SHORTNAME")
time.sleep(2)
try:
    iface.close()
except Exception:
    pass
print("Meshtastic node renamed.")
PYEOF

# Read the GUID back from the radio
GUID=$("$MESH_PYTHON" - <<PYEOF || true
import meshtastic.tcp_interface, time
iface = meshtastic.tcp_interface.TCPInterface('localhost', portNumber=4403)
time.sleep(3)
me = iface.getMyUser()
print(me.get('id', '').lstrip('!'))
try:
    iface.close()
except Exception:
    pass
PYEOF
)
echo "      Hardware GUID: $GUID"

# ── Phase 3: jTAK Identity ────────────────────────────────────────────────────
echo "[3/5] Writing jtak.identity.yaml"
PROVISIONED=$(date -u +"%Y-%m-%dT%H:%M:%S+00:00")
cat > /opt/jtak/config/jtak.identity.yaml <<YAML
# jTAK Hub Identity — written by jtak-provision, never overwritten by deploy
guid: "$GUID"
hub_id: "$HUB_ID"
provisioned: "$PROVISIONED"
YAML

echo "[3/5] Updating jtak.yaml hub section"
python3 - <<PYEOF
import yaml
path = '/opt/jtak/config/jtak.yaml'
with open(path) as f:
    d = yaml.safe_load(f)
d['hub']['id']         = '$HUB_ID'
d['hub']['name']       = '$LONGNAME'
d['hub']['short_name'] = '$SHORTNAME'
d['hq']['hub_id']      = 'hub-$HUB_ID'
with open(path, 'w') as f:
    yaml.dump(d, f, default_flow_style=False, allow_unicode=True)
print('jtak.yaml hub section updated.')
PYEOF

echo "[3/5] Updating bakeoff config tags"
echo "untagged-${HOSTNAME}" > /opt/jtak/data/gps_config_tag.txt
echo "untagged-${HOSTNAME}" > /opt/jtak/data/sdr_config_tag.txt
echo "untagged-${HOSTNAME}" > /opt/jtak/data/rf_config_tag.txt
echo "      GPS/SDR/RF config tags reset to: untagged-${HOSTNAME}"

# ── Phase 4: NGINX jtak-local block ──────────────────────────────────────────
echo "[4/5] Writing nginx jtak-local server block"
cat > /etc/nginx/sites-available/jtak-local <<NGINX
# HTTP-only server block for AP field access — written by jtak-provision
server {
    listen 80;
    listen [::]:80;
    server_name 10.42.0.1 ${HOSTNAME}.local;

    location /jtak/ {
        alias /opt/jtak/frontend/;
        index index.html;
        add_header Cache-Control "no-store, no-cache, must-revalidate";
        expires 0;
        try_files \$uri \$uri/ /jtak/index.html;
    }

    location /jtak/api/ {
        proxy_pass http://127.0.0.1:8420/api/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_read_timeout 86400;
        proxy_buffering off;
        add_header Cache-Control "no-store, no-cache, must-revalidate";
        add_header Pragma "no-cache";
        expires 0;
    }
}
NGINX

# Enable the site if not already symlinked
if [[ ! -L /etc/nginx/sites-enabled/jtak-local ]]; then
  ln -s /etc/nginx/sites-available/jtak-local /etc/nginx/sites-enabled/jtak-local
fi

nginx -t && systemctl reload nginx && echo "      nginx reloaded" || echo "      WARNING: nginx config error — check manually"

# ── Phase 5: Restart Services ────────────────────────────────────────────────
echo "[5/5] Restarting jTAK services"
systemctl restart jtak-api.service
systemctl restart jtak-push.service 2>/dev/null || true
sleep 2
systemctl is-active jtak-api.service && echo "      jtak-api: active" || echo "      jtak-api: FAILED"

# ── Summary ──────────────────────────────────────────────────────────────────
echo ""
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║  Provisioning complete — MANUAL steps required:             ║"
echo "╠══════════════════════════════════════════════════════════════╣"
echo "║  1. Authorize ZT node $NEW_ZT_ID in ZeroTier Central   ║"
echo "║  2. Register hub-$HUB_ID at HQ (POST /api/v1/directory)     ║"
echo "║  3. Set HQ API key in /opt/jtak/config/jtak.yaml            ║"
echo "║     hq.push_token: <new key from HQ admin>                  ║"
echo "║  4. Update GPS/SDR config tags after antenna setup:         ║"
echo "║     echo 'mytag' > /opt/jtak/data/gps_config_tag.txt        ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo ""
echo "  Hardware GUID : $GUID"
echo "  Hostname      : $HOSTNAME"
echo "  Hub ID        : $HUB_ID"
echo "  ZeroTier ID   : $NEW_ZT_ID"
echo "  WiFi AP SSID  : $HOSTNAME"
echo ""
